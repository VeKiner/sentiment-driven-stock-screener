# ============================================================
# 公众舆情股票分析工作流 - 环境变量配置模板
# Public Opinion Analysis Stock Workflow - Environment Variables
#
# 使用方法：复制本文件为 .env 并填入真实配置值
# Usage: Copy this file to .env and fill in your actual values
# ============================================================

# ===== 数据库配置 (Database) =====
# PostgreSQL 连接串，用于行业评级数据持久化
PGDATABASE_URL=postgresql://username:password@localhost:5432/stock_analysis

# ===== 阿里云 OSS 配置 (Aliyun OSS for PDF Storage) =====
# 访问 https://ram.console.aliyun.com/ 创建子账号并获取 AccessKey
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
# OSS 地域 Endpoint，例如：oss-cn-beijing.aliyuncs.com
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS Bucket 名称（需提前在控制台创建并开启公共读权限）
OSS_BUCKET_NAME=your_bucket_name_here

# ===== 企业微信机器人配置 (WeCom Bot) =====
# 在企业微信群聊中：添加机器人 → 复制 Webhook 地址中 key= 后面的值
WECOM_WEBHOOK_KEY=your_wecom_webhook_key_here

# ===== CozeLoop 链路追踪配置（可选 / Optional）=====
# 用于 LangGraph 执行链路的全链路追踪，不配置不影响主功能
COZE_PROJECT_SPACE_ID=your_space_id
COZE_LOOP_API_TOKEN=your_loop_api_token
COZE_LOOP_BASE_URL=https://api.coze.cn

# ===== 日志配置 (Logging) =====
LOG_LEVEL=INFO
# LOG_DIR=/tmp/app/work/logs/bypass
